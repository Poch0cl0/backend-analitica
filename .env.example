# Entorno
ENV=development
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Base de datos (PostgreSQL local)
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@localhost:5432/obstetricare
DB_ECHO=False
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT local (genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=cambia-esta-clave-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Redis (opcional)
REDIS_URL=redis://localhost:6379/0

# Rutas de modelos ML
ML_PREDICTION_PATH=app/ml_models/prediccion
ML_TRIAGE_PATH=app/ml_models/triage
ML_MODELS_PATH=app/ml_models/models
